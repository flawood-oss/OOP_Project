{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++ build project",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++20",
                "-I", "${workspaceFolder}/include",
                "${workspaceFolder}/src/models/Person.cpp",
                "${workspaceFolder}/src/models/Student.cpp",
                "${workspaceFolder}/src/models/Lecturer.cpp",
                "${workspaceFolder}/src/models/HRManager.cpp",
                "${workspaceFolder}/src/controllers/AppController.cpp",
                "${workspaceFolder}/src/views/ConsoleView.cpp",
                "${workspaceFolder}/main.cpp",
                "-o",
                "${workspaceFolder}/UniversityManagement.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile all project on Windows"
        }
    ]
}
